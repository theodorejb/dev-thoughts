{
    "name": "theodorejb/dev-thoughts",
    "description": "Feature poignant quotes and funny sayings related to programming",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Theodore Brown",
            "email": "theodorejb@outlook.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "theodorejb\\DevThoughts\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "theodorejb\\DevThoughts\\Test\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1.40",
        "phpunit/phpunit": "^11.5"
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "analyze": "phpstan analyze",
        "test": "phpunit tests"
    }
}
